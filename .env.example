# Supabase (use service role on the server for inserts if RLS blocks anon)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram (@car-monitor bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: if api.telegram.org is slow on your network
TELEGRAM_API_TIMEOUT_MS=60000

# Optional: protect manual/HTTP cron
CRON_SECRET=

# In-process scheduler (next start on Railway). Set false if you only use HTTP cron.
ENABLE_CRON=true
# Every 4 minutes — 3–5 min range; adjust as needed (standard cron syntax)
CRON_EXPRESSION=*/4 * * * *
# Set true to skip the one-time scan that runs when the Node server starts
# SKIP_INITIAL_SCAN=false

# Scrape toggles
SCRAPE_GUMTREE=true
SCRAPE_CARSALES=true

# When sites return bot/captcha interstitials to simple HTTP clients, we can fall back to Playwright (Chromium).
# After `npm install`, run: `npx playwright install chromium`
USE_PLAYWRIGHT=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=60000
PLAYWRIGHT_POST_LOAD_WAIT_MS=3000
# Optional: use installed Chrome/Edge instead of bundled Chromium (often fewer WAF issues on Windows)
# PLAYWRIGHT_CHANNEL=chrome

# Optional: outbound HTTP(S) proxy (e.g. residential) when Gumtree returns Access denied for VPN/datacenter IPs
# SCRAPE_HTTPS_PROXY=http://user:pass@host:port
# HTTPS_PROXY works too; SCRAPE_HTTPS_PROXY wins if both are set.

# Optional: skip axios for Gumtree and use Chromium immediately (fewer flaky "200 but empty shell" failures)
# GUMTREE_PLAYWRIGHT_FIRST=true

# Optional: full Gumtree search URL (same page you use in a browser; quote if it contains &)
# GUMTREE_SEARCH_URL="https://www.gumtree.com.au/s-cars-vans-utes/automatic/k0c18320?carmileageinkms=__200000&view=gallery&price=__3200.00"
# CARSALES_SEARCH_URL=
