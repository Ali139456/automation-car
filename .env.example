# Supabase (use service role on the server for inserts if RLS blocks anon)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram (@car-monitor bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: protect manual/HTTP cron
CRON_SECRET=

# In-process scheduler (next start on Railway). Set false if you only use HTTP cron.
ENABLE_CRON=true
# Every 4 minutes — 3–5 min range; adjust as needed (standard cron syntax)
CRON_EXPRESSION=*/4 * * * *

# Scrape toggles
SCRAPE_GUMTREE=true
SCRAPE_CARSALES=true

# Override search URLs if site HTML/API changes (full URL with your filters)
# GUMTREE_SEARCH_URL=
# CARSALES_SEARCH_URL=
